# Neon PostgreSQL Database Configuration
# You can connect using a single DATABASE_URL connection string (recommended for Neon):
DATABASE_URL=postgresql://[user]:[password]@[neon_host]/neondb?sslmode=require

# Alternatively, you can use individual variables:
PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=localhost
PG_DATABASE=topos_rag
PG_PORT=5432
PG_SSL=true # Required ONLY if using individual variables above to connect to Neon (ignored when using DATABASE_URL)

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
